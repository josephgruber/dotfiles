{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "palette": {
        "black": "#262B44",
        "blue": "#4B95E9",
        "green": "#59C9A5",
        "orange": "#F07623",
        "red": "#D81E5B",
        "sapling": "#a6d189",
        "white": "#E0DEF4",
        "yellow": "#F3AE35"
    },
    "accent_color": "32",
    "blocks": [
        {
            "type": "prompt",
            "alignment": "left",
            "segments": [
                {
                    "background": "#82AAFF",
                    "foreground": "#011627",
                    "leading_diamond": "\u256d\u2500\ue0b6",
                    "powerline_symbol": "\ue0b0",
                    "options": {
                        "folder_icon": "\uf07c ",
                        "folder_separator_icon": "<#011627>\ue0b1</> ",
                        "hide_root_location": true,
                        "home_icon": "\ueb06 ",
                        "style": "agnoster_short",
                        "max_depth": 3,
                        "mapped_locations": {
                            "/Users/josephgruber/dev/": " ",
                            "/Users/josephgruber/dev/work": "󰦑 ",
                            "/Users/josephgruber/dev/work/sphinx": " "
                        }
                    },
                    "cache": {
                        "duration": "none"
                    },
                    "style": "diamond",
                    "type": "path"
                },
                {
                    "background": "#addb67",
                    "background_templates": [
                        "{{ if or (.Working.Changed) (.Staging.Changed) }}#e4cf6a{{ end }}",
                        "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f78c6c{{ end }}",
                        "{{ if gt .Ahead 0 }}#C792EA{{ end }}",
                        "{{ if gt .Behind 0 }}#c792ea{{ end }}"
                    ],
                    "foreground": "#011627",
                    "powerline_symbol": "\ue0b0",
                    "options": {
                        "branch_icon": "\ue725 ",
                        "fetch_status": true,
                        "fetch_upstream_icon": true
                    },
                    "style": "powerline",
                    "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
                    "type": "git"
                },
                {
                    "type": "claude",
                    "powerline_symbol": "\ue0b0",
                    "trailing_diamond": "\ue0b4",
                    "style": "powerline",
                    "foreground": "#FFFFFF",
                    "background": "#575656",
                    "template": " \udb82\udfc9 {{ .Model.DisplayName }} {{ if ge .TokenUsagePercent 80 }}<#FF0000>{{ else if ge .TokenUsagePercent 50 }}<#FFFF00>{{ else }}<#00FF00>{{ end }}{{ .TokenGaugeUsed }}</> {{ .TokenUsagePercent.String }}% | \ue641 {{ .FormattedDuration }}{{ if gt .FiveHourResetsIn 0 }} | \uf252 {{ .FiveHourResetsIn }}{{ end }}",
                    "options": {
                        "gauge_marked_char": "█",
                        "gauge_unmarked_char": "⣿"
                    }
                }
            ]
        }
    ],
    "version": 4
}
