adjust-cell-height=10%	
copy-on-select = clipboard
desktop-notifications=true
font-family=FiraCode Nerd Font
font-size=12
font-thicken=true
keybind=shift+enter=text:\n
keybind = cmd+shift+right=next_tab
keybind = cmd+shift+left=previous_tab
macos-non-native-fullscreen=true
macos-titlebar-style=tabs
mouse-hide-while-typing=true
quit-after-last-window-closed=true
scrollback-limit=100000000
shell-integration-features=no-cursor
shell-integration-features=cursor,sudo,title 
shell-integration=zsh


# Theme
theme=Dracula
background-opacity = 0.9
background-blur-radius = 20
window-padding-x = 10
window-padding-y = 8
window-theme = auto
window-height=50
window-new-tab-position=end
window-width=180
window-save-state=always


# Cursor. A bar is less distracting than a block when reading long
# output.
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8

# Performance
scrollback-limit = 100000
resize-overlay = always

# Split keybindings. SAND pattern (Split, Across, Navigate, Destroy).
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+w=close_surface
keybind = ctrl+h=goto_split:left
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:top
keybind = cmd+down=goto_split:bottom

# Tab keybindings
keybind = super+t=new_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5

# Quick terminal
# keybind = global:super+grave_accent=toggle_quick_terminal
keybind = global:cmd+shift+1=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.15
