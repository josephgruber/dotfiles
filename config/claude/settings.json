{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "cleanupPeriodDays": 30,
    "env": {
        "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
        "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
        "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
        "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
        "CLAUDE_CODE_NEW_INIT": "1",
        "DISABLE_ERROR_REPORTING": "1",
        "DISABLE_TELEMETRY": "1",
        "DISABLED_CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
        "ENABLE_PROMPT_CACHING_1H": "1",
        "ENABLE_TOOL_SEARCH": "true",
        "USE_BUILTIN_RIPGREP": "true"
    },
    "includeCoAuthoredBy": false,
    "permissions": {
        "allow": [
            "Bash(ast-grep *)",
            "Bash(bat *)",
            "Bash(cat *)",
            "Bash(docker events *)",
            "Bash(docker images *)",
            "Bash(docker ps *)",
            "Bash(fd *)",
            "Bash(find *)",
            "Bash(gemini *)",
            "Bash(git branch *)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git remote *)",
            "Bash(git rev-parse *)",
            "Bash(git show *)",
            "Bash(git stash list *)",
            "Bash(git status *)",
            "Bash(git switch *)",
            "Bash(git symbolic-ref *)",
            "Bash(git tag *)",
            "Bash(glab ci:*)",
            "Bash(glab issue *)",
            "Bash(head *)",
            "Bash(jq *)",
            "Bash(kubectl get:*)",
            "Bash(kubectl describe:*)",
            "Bash(ls *)",
            "Bash(pre-commit *)",
            "Bash(prek *)",
            "Bash(yq *)",
            "Bash(node --version *)",
            "Bash(npm list *)",
            "Bash(npm outdated *)",
            "Bash(npm view *)",
            "Bash(pipenv run *)",
            "Bash(poetry env info *)",
            "Bash(poetry show *)",
            "Bash(pwd *)",
            "Bash(pytest *)",
            "Bash(python *)",
            "Bash(rg *)",
            "Bash(rumdl check *)",
            "Bash(sed *)",
            "Bash(tail *)",
            "Bash(tofu fmt:*)",
            "Bash(tofu test:*)",
            "Bash(tofu validate:*)",
            "Bash(uv pip list *)",
            "Bash(uv run pytest *)",
            "Bash(uv tree *)",
            "Bash(wc *)",
            "mcp__home-assistant",
            "mcp__ide__getDiagnostics",
            "mcp__package-version",
            "mcp__server-fetch__fetch",
            "mcp__server-filesystem__create_directory",
            "mcp__server-filesystem__directory_tree",
            "mcp__server-filesystem__get_file_info",
            "mcp__server-filesystem__list_allowed_directories",
            "mcp__server-filesystem__list_directory",
            "mcp__server-filesystem__read_file",
            "mcp__server-filesystem__read_multiple_files",
            "mcp__server-filesystem__read_text_file",
            "mcp__server-filesystem__search_files",
            "mcp__server-git__git_diff",
            "mcp__server-git__git_diff_unstaged",
            "mcp__server-git__git_log",
            "mcp__server-git__git_add",
            "mcp__server-git__git_status",
            "mcp__server-time",
            "mcp__sonarqube__analyze_code_snippet",
            "mcp__sonarqube__search_my_sonarqube_projects",
            "mcp__sonarqube__show_rule",
            "Edit(**/*.py)",
            "Edit(**/*.md)",
            "Edit(**/*.json)",
            "Read(**/*.md)",
            "Read(**/*.py)",
            "Read(**/*.json)",
            "Read(**/pyproject.toml)",
            "Read(**/requirements*.txt)",
            "Skill(glab)",
            "WebFetch(domain:pypi.org)",
            "Write(**/*.md)",
            "Write(**/*.json)",
            "Write(**/*.py)"
        ],
        "deny": [
            "Bash(bat *.env*)",
            "Bash(cat *.env*)",
            "Bash(curl *| bash*)",
            "Bash(curl *|bash*)",
            "Bash(dd *)",
            "Bash(git * develop)",
            "Bash(git * main)",
            "Bash(git checkout *)",
            "Bash(git push --force *)",
            "Bash(git push *--force *)",
            "Bash(git push *)",
            "Bash(head *.env*)",
            "Bash(less *.env*)",
            "Bash(mkfs *)",
            "Bash(more *.env*)",
            "Bash(rm -fr *)",
            "Bash(sudo *)",
            "Bash(tail *.env*)",
            "Bash(wget *| bash*)",
            "Bash(wget *|bash*)",
            "Edit(.env*)",
            "Edit(~/.bashrc)",
            "Edit(~/.ssh/**)",
            "Edit(~/.zshrc)",
            "Read(.env*)",
            "Read(~/.aws/**)",
            "Read(~/.docker/config.json)",
            "Read(~/.git-credentials)",
            "Read(~/.kube/**)",
            "Read(~/.npm/**)",
            "Read(~/.npmrc)",
            "Read(~/.pypirc)",
            "Read(~/.ssh/**)",
            "Read(~/Library/Keychains/**)"
        ],
        "ask": [
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(git reset --hard *)",
            "Bash(glab api *)",
            "Bash(pip uninstall *)",
            "Bash(python3 *)",
            "Bash(python *)",
            "Bash(uv run *)",
            "mcp__server-filesystem__edit_file",
            "mcp__server-filesystem__move_file",
            "mcp__server-filesystem__write_file",
            "mcp__server-git__git_add"
        ],
        "defaultMode": "default",
        "additionalDirectories": [
            "/Users/josephgruber/dev",
            "/Users/josephgruber/.agents"
        ]
    },
    "model": "sonnet",
    "enableAllProjectMcpServers": true,
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "/Users/josephgruber/.claude/hooks/session_start.py"
                    }
                ]
            }
        ],
        "CwdChanged": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "direnv export bash > \"$CLAUDE_ENV_FILE\" 2>/dev/null || true"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/format-on-write.sh"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/lint-on-write.sh"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh"
    },
    "enabledPlugins": {
        "caveman@caveman": true,
        "claude-md-management@claude-plugins-official": true,
        "code-review@claude-plugins-official": true,
        "code-simplifier@claude-plugins-official": true,
        "context7@claude-plugins-official": true,
        "feature-dev@claude-plugins-official": true,
        "gitlab@claude-plugins-official": false,
        "pr-review-toolkit@claude-plugins-official": true,
        "security-guidance@claude-plugins-official": true,
        "skill-creator@claude-plugins-official": true,
        "superpowers@claude-plugins-official": true,
        "terraform-skill@antonbabenko": true
    },
    "extraKnownMarketplaces": {
        "astral-sh": {
            "source": {
                "source": "github",
                "repo": "astral-sh/claude-code-plugins"
            }
        },
        "caveman": {
            "source": {
                "source": "github",
                "repo": "JuliusBrussee/caveman"
            }
        },
        "antonbabenko": {
            "source": {
                "source": "github",
                "repo": "antonbabenko/terraform-skill"
            }
        }
    },
    "outputStyle": "default",
    "spinnerTipsEnabled": false,
    "alwaysThinkingEnabled": true,
    "autoMemoryEnabled": true,
    "autoDreamEnabled": true
}
