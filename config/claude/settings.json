{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "90",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(command:git diff*)",
      "Bash(command:git log*)",
      "Bash(command:git status*)",
      "Bash(command:ls*)",
      "Bash(pipenv run:*)",
      "Bash(command:pytest*)",
      "Bash(command:rg*)",
      "Bash(find:*)",
      "Bash(git diff:*)",
      "Bash(git switch:*)",
      "Bash(glab issue:*)",
      "Bash(jq:*)",
      "mcp__ide__getDiagnostics",
      "mcp__server-filesystem__directory_tree",
      "mcp__server-filesystem__list_directory",
      "mcp__server-filesystem__read_text_file",
      "mcp__server-git__git_diff",
      "mcp__server-time__get_current_time",
      "Read(**/*.md)",
      "Read(**/*.py)",
      "Read(**/pyproject.toml)",
      "Read(**/requirements*.txt)",
      "Skill(glab)",
      "Write(**/*.md)",
      "Write(**/*.py)"
    ],
    "deny": [
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(wget *|bash*)",
      "Bash(wget *| bash*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)",
      "Bash(pip uninstall*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.ssh/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/Library/Keychains/**)",
      "mcp__server-git__git_add"
    ],
    "ask": [
      "Bash(glab api:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "//Users/josephgruber/dev",
      "~/.claude"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff check --fix {{files}} 2>/dev/null || true && ruff format {{files}} 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "mypy {{files}} --no-error-summary 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; if [[ \"$f\" == *.md ]]; then rumdl fmt \"$f\" 2>/dev/null || true; fi; }",
            "statusMessage": "Formatting Markdown..."
          },
          {
            "type": "agent",
            "prompt": "Extract the file path from $ARGUMENTS and run mcp__ide__getDiagnostics on it to check for errors"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "astral@astral-sh": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": true,
    "terraform-module-generation@hashicorp": true,
    "terraform-provider-development@hashicorp": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    },
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    }
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": true
}
